# ── Inference ─────────────────────────────────────────────────────────────
NEBIUS_API_KEY=XXX

# ── MLflow ────────────────────────────────────────────────────────────────
# For standalone Airflow: keep as-is (MLflow runs locally on port 5000)
# For Docker Compose: set to http://mlflow:5000 (resolved via Docker network)
MLFLOW_TRACKING_URI=http://localhost:5000

# ── Airflow (docker-compose only) ─────────────────────────────────────────
AIRFLOW_UID=50000

# ── Object Storage / S3 (optional – leave blank to keep artifacts local) ──
S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL=
AWS_DEFAULT_REGION=us-east-1
